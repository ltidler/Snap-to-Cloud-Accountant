# ==========================================
# 1. n8n 核心运行配置 (Variables & Secrets)
# ==========================================
N8N_ENCRYPTION_KEY=你的随机加密密钥(Secrets)
N8N_USER_MANAGEMENT_DISABLED=false
GENERIC_TIMEZONE=Asia/Kuala_Lumpur

# ==========================================
# 2. Supabase 数据库连接 (已在 GitHub Secrets 设置)
# ==========================================
DB_TYPE=postgresdb
DB_POSTGRESDB_HOST=你的Supabase项目Host
DB_POSTGRESDB_PORT=5432
DB_POSTGRESDB_DATABASE=postgres
DB_POSTGRESDB_USER=postgres
DB_POSTGRESDB_PASSWORD=你的数据库密码(Secrets)
DB_POSTGRESDB_SCHEMA=public
DB_POSTGRESDB_SSL_REJECT_UNAUTHORIZED=false

# ==========================================
# 3. 网络与协议配置 (确保 Webhook 正常)
# ==========================================
N8N_PROTOCOL=https
# 如果在 HF 运行，通常需要配置以下项
# N8N_HOST=你的HF项目子域名.hf.space

# ==========================================
# 4. 工作流所需的外部凭据 (参考项)
# ==========================================
# GEMINI_API_KEY=从Google AI Studio获取
# TELEGRAM_BOT_TOKEN=从BotFather获取
