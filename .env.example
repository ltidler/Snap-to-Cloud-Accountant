# ==========================================
# n8n 基础核心配置 (Basic Config)
# ==========================================
N8N_ENCRYPTION_KEY=你的随机加密密钥(不可丢失)
N8N_USER_MANAGEMENT_DISABLED=false
GENERIC_TIMEZONE=Asia/Kuala_Lumpur

# ==========================================
# 数据库配置 (Supabase / Postgres)
# ==========================================
DB_TYPE=postgresdb
DB_POSTGRESDB_HOST=你的Supabase主机地址
DB_POSTGRESDB_PORT=5432
DB_POSTGRESDB_DATABASE=postgres
DB_POSTGRESDB_USER=postgres
DB_POSTGRESDB_PASSWORD=你的数据库密码
DB_POSTGRESDB_SCHEMA=public
# SSL 模式通常在远程连接 Supabase 时需要
DB_POSTGRESDB_SSL_REJECT_UNAUTHORIZED=false

# ==========================================
# Telegram & Gemini (用于工作流凭据参考)
# ==========================================
# 这些虽然在 n8n 界面里填，但在 ENV 里备选可以防止丢失
TELEGRAM_BOT_TOKEN=你的机器人Token
GEMINI_API_KEY=你的GeminiKey
